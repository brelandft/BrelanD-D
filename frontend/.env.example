# Copy this file to .env and fill in your Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# VITE_SUPABASE_ANON_KEY is safe to expose in the built frontend — see
# src/lib/supabaseClient.js for why. Never put the service_role key here.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Same value you set with `supabase secrets set APP_SHARED_SECRET=...` —
# this one IS safe to expose (it just gates the Edge Function from
# random internet traffic, not from people with the app link).
VITE_APP_SHARED_SECRET=pick-something-random-and-long
